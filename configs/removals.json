{
  "tool": "removals",
  "name": "MoveEstimate",
  "kicker": "Estimates in under 60 seconds",
  "steps": [
    {
      "id": "property_size",
      "type": "single-select",
      "title": "What size property are you moving from?",
      "subtitle": "This helps us estimate the size of the move.",
      "options": [
        { "label": "Studio", "value": "studio" },
        { "label": "1 Bedroom", "value": "1_bed" },
        { "label": "2 Bedroom", "value": "2_bed" },
        { "label": "3 Bedroom", "value": "3_bed" },
        { "label": "4 Bedroom", "value": "4_bed" },
        { "label": "5+ Bedroom", "value": "5_plus" }
      ]
    },
    {
      "id": "moving_from",
      "type": "text-input",
      "title": "Where are you moving from?",
      "subtitle": "Enter your current postcode or address.",
      "placeholder": "Start typing postcode or address"
    },
    {
      "id": "moving_to",
      "type": "text-input",
      "title": "Where are you moving to?",
      "subtitle": "Enter your destination postcode or address.",
      "placeholder": "Start typing postcode or address"
    },
    {
      "id": "extras",
      "type": "multi-select",
      "title": "Do you need any additional services?",
      "subtitle": "Select any that apply.",
      "options": [
        { "label": "Full packing service", "value": "full_packing" },
        { "label": "Fragile item packing", "value": "fragile_packing" },
        { "label": "Furniture dismantling", "value": "dismantling" },
        { "label": "No additional services", "value": "none" }
      ]
    }
  ]
}
